{
  "name": "portfolio-agent",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "eval": "eve eval --max-concurrency 2",
    "eval:ci": "eve eval --strict --max-concurrency 2 --junit .eve/junit.xml",
    "start": "eve start",
    "typecheck": "tsgo",
    "smoke:dm-style": "tsgo -p tsconfig.dm-style-smoke.json && node .tmp/dm-style-smoke/evals/dm-response-style-smoke.js",
    "smoke:fit-check": "tsgo -p tsconfig.fit-check-smoke.json && node .tmp/fit-check-smoke/evals/fit-check-smoke.js",
    "smoke:structured-output": "tsgo -p tsconfig.structured-smoke.json && node .tmp/structured-output-smoke/evals/structured-output-smoke.js"
  },
  "dependencies": {
    "ai": "7.0.0-beta.178",
    "eve": "^0.11.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": "24.x"
  }
}
